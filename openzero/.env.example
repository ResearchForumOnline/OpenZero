# OpenZero local configuration example.
# Copy to .env on the machine running OpenZero. Never commit real .env files.

ACTIVE_MODEL=gemma3:4b
COMP_MODE=balanced
SERVER_PORT=1024

# Hive/federation is optional and local-first by default.
HIVE_MIND_ENABLED=false
OPENZERO_HIVE_MODE=local
OPENZERO_HIVE_URL=https://openzero.talktoai.org/api/hive
OPENZERO_HIVE_MIRRORS=
OPENZERO_HIVE_SHARE_MODE=manual
OPENZERO_HIVE_BLOCK_RISKY_CONTENT=true
OPENZERO_HIVE_REMOTE_LOOKUP_ENABLED=false
OPENZERO_HIVE_BACKGROUND_PUSH=false

# Local API bridge.
OPENZERO_LOCAL_API_ENABLED=true
OPENZERO_API_KEYS=

# Optional provider keys. Leave blank unless you choose to use them.
GROQ_API_KEY=
OPENAI_API_KEY=
FEATHERLESS_API_KEY=

# Local operator settings.
VOICE_ENABLED=false
MOLTBOT_ENABLED=false
SUDO_PASS=
