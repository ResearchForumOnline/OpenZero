# OpenZero local configuration example.
# Copy to .env on the machine running OpenZero. Never commit real .env files.

OPENZERO_VERSION=5.4.0
OPENZERO_DOMAIN=https://openzero.talktoai.org
SERVER_PORT=1024

# Local model runtime.
ACTIVE_MODEL=gemma4:e4b
LOCAL_ENGINE=ollama
COMP_MODE=hybrid
OPENZERO_CPU_PROFILE=balanced
OPENZERO_OLLAMA_THREADS=0
OPENZERO_OLLAMA_NUM_BATCH=512
OPENZERO_OLLAMA_KEEP_ALIVE=10m
OPENZERO_SPARK_MODE=auto
OPENZERO_SPARK_DRAFT_MODEL=qwen2.5:0.5b
OPENZERO_SPARK_CONFIDENCE_THRESHOLD=0.58
OPENZERO_SPARK_MAX_DRAFT_TOKENS=384
OPENZERO_SPARK_SHOW_TRACE=false

# Optional BitNet lane.
BITNET_ENABLED=false
BITNET_THREADS=0
BITNET_MODEL_ALIAS=bitnet-b1.58-2b-4t
BITNET_CONTEXT_WINDOW=4096

# ZeroThink / local OpenAI-compatible API bridge.
OPENZERO_API_ENABLED=false
OPENZERO_API_KEY_HASH=
OPENZERO_API_KEY_HINT=

# Hive/federation is optional and private/local-first by default.
HIVE_MIND_ENABLED=false
OPENZERO_HIVE_MODE=standalone
OPENZERO_HIVE_URL=https://openzero.talktoai.org/api/hive
OPENZERO_HIVE_MIRRORS=
OPENZERO_HIVE_SHARE_MODE=manual
OPENZERO_HIVE_BLOCK_RISKY_CONTENT=true
OPENZERO_HIVE_REMOTE_LOOKUP_ENABLED=false
OPENZERO_HIVE_BACKGROUND_PUSH=false

# Voice and vision.
VISION_ENABLED=true
VOICE_ENABLED=false
VOICE_TTS_ENABLED=false
VOICE_AUTO_LISTEN=false
VOICE_STT_MODEL=base
VOICE_TTS_BACKEND=piper
VOICE_TTS_VOICE=en_GB-alan-medium
VOICEBOX_ENABLED=false
VOICEBOX_URL=http://127.0.0.1:17493
VOICEBOX_PROFILE=
VOICEBOX_ENGINE=auto
VOICEBOX_LANGUAGE=en
VOICEBOX_PERSONALITY=false
VOICEBOX_FALLBACK_PIPER=true

# Optional provider keys. Leave blank unless you choose to use them.
GROQ_API_KEY=
SERPER_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Local operator settings.
SUDO_PASS=
